{
    "name": "nowo-tech/doctrine-deadlock-retry-bundle",
    "description": "Symfony bundle that retries Doctrine flush and custom operations on DBAL deadlock exceptions with configurable profiles.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "symfony",
        "bundle",
        "doctrine",
        "dbal",
        "deadlock",
        "retry",
        "orm",
        "transaction"
    ],
    "homepage": "https://github.com/nowo-tech/DoctrineDeadlockRetryBundle",
    "support": {
        "issues": "https://github.com/nowo-tech/DoctrineDeadlockRetryBundle/issues",
        "source": "https://github.com/nowo-tech/DoctrineDeadlockRetryBundle",
        "docs": "https://github.com/nowo-tech/DoctrineDeadlockRetryBundle/tree/main/docs",
        "changelog": "https://github.com/nowo-tech/DoctrineDeadlockRetryBundle/blob/main/docs/CHANGELOG.md"
    },
    "authors": [
        {
            "name": "Héctor Franco Aceituno",
            "email": "hectorfranco@nowo.tech",
            "homepage": "https://github.com/HecFranco",
            "role": "Developer"
        },
        {
            "name": "Nowo.tech",
            "homepage": "https://nowo.tech"
        }
    ],
    "require": {
        "php": ">=8.2 <8.6",
        "doctrine/dbal": "^3.8.2 || ^4.0",
        "doctrine/doctrine-bundle": "^2.8 || ^3.0",
        "doctrine/orm": "^2.13 || ^3.0",
        "symfony/config": "^6.4 || ^7.0 || ^8.0 || ^8.1",
        "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0 || ^8.1",
        "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0 || ^8.1"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.0",
        "rector/rector": "^2.0",
        "symfony/yaml": "^6.4 || ^7.0 || ^8.0 || ^8.1"
    },
    "autoload": {
        "psr-4": {
            "Nowo\\DoctrineDeadlockRetryBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nowo\\DoctrineDeadlockRetryBundle\\Tests\\": "tests/"
        }
    },
    "archive": {
        "exclude": ["/demo", "/.cursor"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit --colors=always",
        "test-unit": "phpunit --testsuite=Unit",
        "test-integration": "phpunit --testsuite=Integration",
        "test-coverage": "phpunit --colors=always --coverage-html coverage --coverage-clover coverage.xml --coverage-text",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "rector": "rector process",
        "rector-dry": "rector process --dry-run --no-progress-bar",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "update": "composer update --no-interaction",
        "validate": "composer validate --strict",
        "qa": [
            "@cs-check",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run PHPUnit tests",
        "test-unit": "Run Unit tests only",
        "test-coverage": "Run PHPUnit tests with code coverage",
        "cs-check": "Check code style with PHP-CS-Fixer",
        "cs-fix": "Fix code style with PHP-CS-Fixer",
        "rector": "Apply Rector refactoring",
        "rector-dry": "Run Rector in dry-run mode",
        "phpstan": "Run PHPStan static analysis",
        "update": "Update composer.lock (composer update)",
        "validate": "Validate composer.json (composer validate --strict)",
        "qa": "Run all quality assurance checks"
    },
    "suggest": {
        "symfony/flex": "For automatic recipe installation"
    }
}
